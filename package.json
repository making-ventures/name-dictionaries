{
  "name": "@mkven/name-dictionaries",
  "version": "0.1.0",
  "description": "Russian and English name dictionaries for data generation",
  "author": "Damir Manapov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/making-ventures/name-dictionaries.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "data"
  ],
  "keywords": [
    "names",
    "surnames",
    "dictionaries",
    "data-generation",
    "russian",
    "english"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome check --error-on-warnings .",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc -p tsconfig.check.json",
    "build": "tsc",
    "test": "vitest run",
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "prepublishOnly": "pnpm build",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "bash all-checks.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@release-it/conventional-changelog": "^11.0.0",
    "@types/node": "^25.9.0",
    "release-it": "^20.0.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
